LANG_ENGLISH        "^1REZNOV: ^7Sergei ha preso in giro Dragovich davanti alle persone sbagliate..."

REFERENCE           VORKUTA_VOX_VOR1_S1_036A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Per punirlo, Dragovich gli ha tagliato la lingua con un falcetto arrugginito..."

REFERENCE           VORKUTA_VOX_VOR1_S1_600A_MASO_M
LANG_ENGLISH        "^1MASON: ^7Merda! Devi proprio colpire cosě forte?"

REFERENCE           VORKUTA_VOX_VOR1_S1_900A_INTE
LANG_ENGLISH        "^1INTERROGATORE: ^7Viktor Reznov."

REFERENCE           VORKUTA_VOX_VOR1_S1_902A_MASO
LANG_ENGLISH        "^1MASON: ^7Il mio amico."

REFERENCE           VORKUTA_VOX_VOR1_S1_903A_MASO
LANG_ENGLISH        "^1MASON: ^7Avevano usato i lacrimogeni. Non riuscivo a respirare."

REFERENCE           VORKUTA_VOX_VOR1_S1_904A_INTE
LANG_ENGLISH        "^1INTERROGATORE: ^7Viktor Reznov era ancora con te?"

REFERENCE           VORKUTA_VOX_VOR1_S1_906A_MASO
LANG_ENGLISH        "^1MASON: ^7Non mi ha mai lasciato."

REFERENCE           VORKUTA_VOX_VOR1_S1_907A_INTE
LANG_ENGLISH        "^1INTERROGATORE: ^7Quella č stata l'ultima volta che hai visto Victor Reznov?"

REFERENCE           VORKUTA_VOX_VOR1_S1_909A_MASO
LANG_ENGLISH        "^1MASON: ^7Sě. Almeno per un po'..."

REFERENCE           VORKUTA_VOX_VOR1_S2_037A_RRD4
LANG_ENGLISH        "^1PRIGIONIERO RUSSO: ^7Fallo, Reznov!"

REFERENCE           VORKUTA_VOX_VOR1_S2_038A_RRD4
LANG_ENGLISH        "^1PRIGIONIERO RUSSO: ^7Andiamo! Presto! Presto!"

REFERENCE           VORKUTA_VOX_VOR1_S2_039A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Pazienza, compagni! Pazienza... Va tutto secondo i piani miei e di Mason."

REFERENCE           VORKUTA_VOX_VOR1_S2_040A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Il secondo passo?!?"

REFERENCE           VORKUTA_VOX_VOR1_S2_041A_CROW
LANG_ENGLISH        "^1FOLLA: ^7Uscire dalle tenebre!"

REFERENCE           VORKUTA_VOX_VOR1_S2_042A_RRD2_M
LANG_ENGLISH        "^1PRIGIONIERO RUSSO: ^7Reznov, puoi fidarti dell'Americano?"

REFERENCE           VORKUTA_VOX_VOR1_S2_043A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Sicurissimo."

REFERENCE           VORKUTA_VOX_VOR1_S2_044A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Non č molto diverso da noi... Puoi fidarti di Mason, come ti fidi di me."

REFERENCE           VORKUTA_VOX_VOR1_S2_045A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Traditi. Dimenticati. Abbandonati."

REFERENCE           VORKUTA_VOX_VOR1_S2_046A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7A Vorkuta, siamo TUTTI fratelli... Io e Mason siamo uguali!"

REFERENCE           VORKUTA_VOX_VOR1_S2_047A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Mason, con me!"

REFERENCE           VORKUTA_VOX_VOR1_S2_048A_MASO
LANG_ENGLISH        "^1MASON: ^7Reznov, devi dire ai tuoi che č una missione suicida."

REFERENCE           VORKUTA_VOX_VOR1_S2_049A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Non si puň vincere senza qualche sacrificio, Mason..."

REFERENCE           VORKUTA_VOX_VOR1_S2_050A_REZN
LANG_ENGLISH        "^1REZNOV: ^7E noi Russi lo sappiamo meglio di chiunque altro."

REFERENCE           VORKUTA_VOX_VOR1_S2_051A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Preparatevi, uomini!!!"

REFERENCE           VORKUTA_VOX_VOR1_S2_054A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Stai indietro, Mason... Aspetta che il balcone sia libero!"

REFERENCE           VORKUTA_VOX_VOR1_S2_602A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Mason, prendi l'arma!"

REFERENCE           VORKUTA_VOX_VOR1_S3_055A_RRD2
LANG_ENGLISH        "^1PRIGIONIERO RUSSO: ^7La torre ci farŕ a pezzi!"

REFERENCE           VORKUTA_VOX_VOR1_S3_056A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Abbi fede, compagno!"

REFERENCE           VORKUTA_VOX_VOR1_S3_057A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Mason! Vieni qui!"

REFERENCE           VORKUTA_VOX_VOR1_S3_058A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Il terzo passo?!?"

REFERENCE           VORKUTA_VOX_VOR1_S3_059A_MASO
LANG_ENGLISH        "^1MASON: ^7Far piovere fuoco!"

REFERENCE           VORKUTA_VOX_VOR1_S3_060A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Guardate con che abilitŕ Mason trasforma tutto in un'arma..."

REFERENCE           VORKUTA_VOX_VOR1_S3_062A_REZN
LANG_ENGLISH        "^1REZNOV: ^7URA! Non perdete mai la fiducia, amici... MAI!"

REFERENCE           VORKUTA_VOX_VOR1_S3_063A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Via!"

REFERENCE           VORKUTA_VOX_VOR1_S3_064A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Sta' al riparo!"

REFERENCE           VORKUTA_VOX_VOR1_S3_065A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Non fermarti!"

REFERENCE           VORKUTA_VOX_VOR1_S3_066A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Fianco sinistro!"

REFERENCE           VORKUTA_VOX_VOR1_S3_067A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Fianco destro!"

REFERENCE           VORKUTA_VOX_VOR1_S3_068A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Lŕ, l'infermeria!"

REFERENCE           VORKUTA_VOX_VOR1_S3_069A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Alla raffineria!"

REFERENCE           VORKUTA_VOX_VOR1_S3_070A_REZN
LANG_ENGLISH        "^1REZNOV: ^7I compagni di tutta Vorkuta si uniranno alla nostra causa!"

REFERENCE           VORKUTA_VOX_VOR1_S3_071A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Sě! Sě, amici miei!!!"

REFERENCE           VORKUTA_VOX_VOR1_S3_072A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Mesi di pianificazione, Mason."

REFERENCE           VORKUTA_VOX_VOR1_S3_073A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Non ci fermeremo."

REFERENCE           VORKUTA_VOX_VOR1_S3_074A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Non esiteremo."

REFERENCE           VORKUTA_VOX_VOR1_S3_075A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Otterremo la libertŕ... o moriremo!"

REFERENCE           VORKUTA_VOX_VOR1_S3_076A_REZN
LANG_ENGLISH        "^1REZNOV: ^7Di qua!"

REFERENCE           VORKUTA_VOX_VOR1_S3_077A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Sergei! Apri gli armadietti delle armi!"

REFERENCE           VORKUTA_VOX_VOR1_S3_078A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Mason! Sali sulla torre e aiuta la rivolta a sud!"

REFERENCE           VORKUTA_VOX_VOR1_S3_079A_MASO
LANG_ENGLISH        "^1MASON: ^7E tu, Reznov?"

REFERENCE           VORKUTA_VOX_VOR1_S3_080A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Affinché il nostro piano funzioni, ognuno deve fare la sua parte."

REFERENCE           VORKUTA_VOX_VOR1_S3_081A_MASO
LANG_ENGLISH        "^1MASON: ^7Passo quattro... Sguinzagliare l'orda."

REFERENCE           VORKUTA_VOX_VOR1_S3_082A_REZN_M
LANG_ENGLISH        "^1REZNOV: ^7Io raduno gli uomini!"

REFERENCE           VORKUTA_VOX_VOR1_S3_083A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Compagni di Vorkuta, č venuto il momento di insorgere contro gli oppressori!"

REFERENCE           VORKUTA_VOX_VOR1_S3_084A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Oggi scopriranno di che pasta sono fatti i veri Russi!"

REFERENCE           VORKUTA_VOX_VOR1_S3_085A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo dato il nostro sangue per la patria."

REFERENCE           VORKUTA_VOX_VOR1_S3_086A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo risposto alla sua chiamata senza esitare."

REFERENCE           VORKUTA_VOX_VOR1_S3_087A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo immolato la nostra gioventů, i nostri cuori e le nostre anime per proteggerla."

REFERENCE           VORKUTA_VOX_VOR1_S3_088A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo combattuto fianco a fianco come fratelli contro i nazisti."

REFERENCE           VORKUTA_VOX_VOR1_S3_089A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo strisciato nel fango e nel sangue per conquistare una vittoria maestosa..."

REFERENCE           VORKUTA_VOX_VOR1_S3_090A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Non per le medaglie o la gloria... ma perché era giusto!"

REFERENCE           VORKUTA_VOX_VOR1_S3_091A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo combattuto per vendicarci..."

REFERENCE           VORKUTA_VOX_VOR1_S3_092A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7E quando Berlino č caduta, come ci hanno ripagati i nostri leader?"

REFERENCE           VORKUTA_VOX_VOR1_S3_093A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Al ritorno, non ci attendeva un benvenuto da eroi... ma sospetti e persecuzioni."

REFERENCE           VORKUTA_VOX_VOR1_S3_094A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Agli occhi dei nostri leader, eravamo stati contaminati dal capitalismo occidentale."

REFERENCE           VORKUTA_VOX_VOR1_S3_095A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Strappati alle braccia dei nostri cari, ci siamo ritrovati qui... "

REFERENCE           VORKUTA_VOX_VOR1_S3_096A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7In questo posto... Questo posto orribile..."

REFERENCE           VORKUTA_VOX_VOR1_S3_097A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Qui abbiamo sofferto, senza speranza di libertŕ... o di giustizia."

REFERENCE           VORKUTA_VOX_VOR1_S3_098A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo faticato nelle miniere di Dragovich, fino a strapparci la carne dalle ossa..."

REFERENCE           VORKUTA_VOX_VOR1_S3_099A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo visto i nostri compagni soccombere alle malattie..."

REFERENCE           VORKUTA_VOX_VOR1_S3_100A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Abbiamo sofferto la fame e siamo stati picchiati. Ma non sono riusciti a spezzarci!"

REFERENCE           VORKUTA_VOX_VOR1_S3_101A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Oggi invieremo un messaggio ai nostri leader corrotti e arroganti. "

REFERENCE           VORKUTA_VOX_VOR1_S3_102A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Hanno finito di arricchirsi con il lavoro del popolo."

REFERENCE           VORKUTA_VOX_VOR1_S3_103A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Hanno finito di torturare la povera gente."

REFERENCE           VORKUTA_VOX_VOR1_S3_104A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Č tempo che cadano..."

REFERENCE           VORKUTA_VOX_VOR1_S3_105A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Noi non saremo dimenticati."

REFERENCE           VORKUTA_VOX_VOR1_S3_106A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Oggi, compagni..."

REFERENCE           VORKUTA_VOX_VOR1_S3_107A_REZN_F
LANG_ENGLISH        "^1REZNOV: ^7Vorkuta... BRUCIA!!!"

REFERENCE           VORKUTA_VOX_VOR1_S3_108A_RRD3
